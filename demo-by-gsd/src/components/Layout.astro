---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "快速预览和选择 UI 风格，一键复制 prompt 到 CLAUDE.md" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen">
    <slot />
  </body>
</html>
